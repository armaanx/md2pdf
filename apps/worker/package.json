{
  "name": "@md2pdf/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "pnpm exec dotenv -e ../../.env -- tsx src/index.ts",
    "healthcheck": "pnpm exec dotenv -e ../../.env -- tsx src/healthcheck.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@md2pdf/core": "workspace:*",
    "@md2pdf/db": "workspace:*",
    "@md2pdf/renderer": "workspace:*",
    "bullmq": "^5.58.2"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
