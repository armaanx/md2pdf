{
  "name": "md2pdf-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @md2pdf/web",
    "dev:worker": "npm run dev --workspace @md2pdf/worker",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @md2pdf/db",
    "db:migrate": "npm run db:migrate --workspace @md2pdf/db",
    "render:sample": "node scripts/render-markdown-pdf.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "prisma": "^6.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}

